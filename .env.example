OPENAQ_API_KEY=
OPENAQ_BASE_URL=https://api.openaq.org/v3

# TP.HCM rough bounding box: min_lon,min_lat,max_lon,max_lat
HCMC_BBOX=106.45,10.35,107.05,11.15

# Leave empty for local Parquet under data/. Example: hdfs://namenode:9000/aqi-hcmc
HDFS_BASE_PATH=
# Optional for Windows clients writing to a single-user local HDFS in WSL.
# Set this to the HDFS owner user, for example: minhduy
HADOOP_USER_NAME=

MEASUREMENTS_PATH=data/parquet/measurements
PREDICTIONS_PATH=data/predictions/forecast_24h.json
PREDICTIONS_PARQUET_PATH=data/predictions/forecast_24h_parquet
METRICS_PATH=data/predictions/metrics.json
MODELS_PATH=models/aqi_forecast

# Optional local training runtime controls. Leave empty for the default model sizes.
AQI_RF_NUM_TREES=
AQI_RF_MAX_DEPTH=
AQI_GBT_MAX_ITER=
AQI_GBT_MAX_DEPTH=
AQI_GBT_STEP_SIZE=
